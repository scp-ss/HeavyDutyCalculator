pkgname=Heavy Duty Calculator
pkgver=0.1.0
pkgrel=1
pkgdesc="A calculator that has all the feautres I thought were necessary"
arch=('x86_64')
url="https://github.com/yourname/Heavy Duty Calculator"
license=('MIT')
depends=('cmake' 'rust' 'cargo' 'julia' 'gmp')
source=("https://github.com/yourname/Heavy Duty Calculator/archive/refs/tags/v$pkgver.tar.gz"
        "Heavy Duty Calculator.png"
        "Heavy Duty Calculator.desktop")
sha256sums=('SKIP' 'SKIP' 'SKIP')

build() {
  cmake -B build -S .
  make -C build

  cd src-rust
  cargo build --release
  cd ..

  julia --project=src-julia src-julia/bigmath.jl
}

package() {
  # Install binaries
  install -Dm755 build/mycppbinary "$pkgdir/usr/bin/mycppbinary"
  install -Dm755 src-rust/target/release/myrustbinary "$pkgdir/usr/bin/myrustbinary"

  # Install Julia script
  install -Dm644 src-julia/bigmath.jl "$pkgdir/usr/share/Heavy Duty Calculator/bigmath.jl"

  # Install icon
  install -Dm644 Heavy Duty Calculator.png "$pkgdir/usr/share/pixmaps/Heavy Duty Calculator.png"

  # Install desktop entry
  install -Dm644 Heavy Duty Calculator.desktop "$pkgdir/usr/share/applications/Heavy Duty Calculator.desktop"
}



